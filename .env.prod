# === PDAM Chatbot AI - Development Config ===

# Security
SECRET_KEY=pdam-dev-secret-key-2024-change-in-production

# Environment
ENVIRONMENT=development
DEBUG=true

# Ollama - Development (CPU Mode)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_NUM_GPU=0
OLLAMA_NUM_THREAD=16
OLLAMA_TIMEOUT=120

# Redis Cache
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=true

# Performance
WORKERS=4
HTTP_POOL_SIZE=50