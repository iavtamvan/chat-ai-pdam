# ============================================
# PDAM Chatbot AI - Git Ignore
# ============================================

# === Environment ===
.env
.env.local
.env.*.local
*.env

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
.venv/
*.egg-info/
.eggs/
dist/
build/

# === Node.js ===
node_modules/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# === Nuxt.js ===
.nuxt/
.output/
.nitro/
.cache/

# === IDE ===
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Docker ===
docker-compose.override.yml

# === Data & Uploads ===
backend/documents/uploads/*
backend/documents/processed/*
backend/vectordb/*
backend/logs/*
!backend/documents/uploads/.gitkeep
!backend/documents/processed/.gitkeep
!backend/vectordb/.gitkeep
!backend/logs/.gitkeep

# === WhatsApp Sessions ===
whatsapp-bot/sessions/*
!whatsapp-bot/sessions/.gitkeep

# === SSL Certificates ===
docker/nginx/ssl/*
!docker/nginx/ssl/.gitkeep

# === Temp Files ===
*.tmp
*.temp
*.log
*.bak

# === Test ===
coverage/
.pytest_cache/
.coverage
htmlcov/
