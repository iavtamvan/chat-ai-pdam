# ============================================
# PDAM Chatbot AI - Optimized Environment
# High Performance Configuration
# ============================================

# === Application ===
APP_NAME="PDAM Chatbot AI"
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=8

# === Security ===
# PENTING: Ganti dengan key yang kuat!
SECRET_KEY=your-super-secret-key-change-this-in-production-2024
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === PDAM Auth ===
PDAM_AUTH_API_URL=https://gateway.pdamkotasmg.co.id/api-gw/portal-pegawai/api/auth
PDAM_AUTH_TIMEOUT=10

# === Redis Cache (CRITICAL!) ===
REDIS_URL=redis://redis:6379/0
REDIS_TTL_EMBEDDINGS=86400
REDIS_TTL_RESPONSES=3600
CACHE_ENABLED=true

# === Ollama LLM - GPU Optimized ===
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=60
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_GPU=99
OLLAMA_NUM_THREAD=16
OLLAMA_TEMPERATURE=0.7

# === Vector DB ===
CHROMA_PERSIST_DIR=./vectordb
CHROMA_COLLECTION_NAME=pdam_documents

# === RAG Settings ===
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=3
SIMILARITY_THRESHOLD=0.75

# === Performance ===
HTTP_POOL_SIZE=100
EMBEDDING_PARALLEL=true
EMBEDDING_BATCH_SIZE=32
